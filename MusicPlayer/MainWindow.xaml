<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="MusicPlayer.MainWindow"
        Title="Silverlight FM" Height="600" Width="400"
        MinHeight="600"
        MinWidth="400"
        WindowStyle="None">

    <Window.Resources>
        <Style x:Key="ImageButton" TargetType="{x:Type Button}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Image x:Name="NormalImage"
                                   Source="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>

                            <Image x:Name="HoverImage"
                                   Source="{Binding Uid, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                   Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NormalImage" Property="Opacity" Value="0"/>
                                <Setter TargetName="HoverImage" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverImage" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>



    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="LightSlateGray" Offset="0"/>
            <GradientStop Color="SlateGray" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>



    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" MinHeight="40"/>
            <RowDefinition Height="Auto" MinHeight="35"/>
            <!-- Folder button -->
            <RowDefinition/>
            <!-- Album art + text -->
            <RowDefinition Height="Auto"/>
            <!-- Media buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Slider -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Drag Region -->
        <Grid Grid.Row="0"
              Grid.ColumnSpan="3"
              Background="Transparent"
              MouseLeftButtonDown="DragWindow"/>

        <!-- Window Control Buttons -->
        <StackPanel Grid.Row="0"
                Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,0,5,0"
                Width="120"
                Height="33">

            <!-- Minimize Button -->
            <Button x:Name="Min"
                    Width="55"
                    Height="33"
                    Margin="0,0,10,0"
                    Style="{StaticResource ImageButton}"
                    Tag="/Art/min.png"
                    Uid="/Art/min_highlight.png"
                    Click="Min_Click"/>

            <!-- Exit Button -->
            <Button x:Name="Exit"
                    Width="55"
                    Height="33"
                    Style="{StaticResource ImageButton}"
                    Tag="/Art/close.png"
                    Uid="/Art/close_highlight.png"
                    Click="Exit_Click"/>

        </StackPanel>

        <Button x:Name="Library"
                Content="Library"
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Left"
                Margin="10,0,0,0"
                Width="37" Height="20" VerticalAlignment="Center" Click="Library_Click"/>
        
        <Button x:Name="Playlists"
                Content="Playlist"
                Grid.Row="1"
                Grid.Column="1"
                HorizontalAlignment="Center"
                Margin="0,0,0,0"
                Width="37" Height="20" VerticalAlignment="Center" Click="Playlists_Click"
                />


        <!-- Folder Button -->
        <Button x:Name="FolderFinder"
                Content="Folder"
                Grid.Row="1"
                Grid.Column="2"
                HorizontalAlignment="Right"
                Margin="0,0,10,0"
                Click="FindFolder" Width="37" Height="20" VerticalAlignment="Center"/>


        <Grid x:Name="PlayerView"
              Grid.Row="2"
              Grid.RowSpan="3"
              Grid.ColumnSpan="3">

            <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Album art, Artist, Song name -->
            <Grid Grid.Row="0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

                <StackPanel x:Name="SongInfoPanel"
                        Height="370"
                        Width="360"
                        Margin="0,0,0,0">

                    <StackPanel.Background>
                            <ImageBrush ImageSource="/Art/Music player window2.png"/>
                    </StackPanel.Background>

                    <!-- Artist Name -->
                    <Viewbox HorizontalAlignment="Left"
                             Stretch="Uniform"
                             StretchDirection="DownOnly"
                             Height="18"
                             Width="197"
                             Margin="10,4,0,0">

                        <TextBlock x:Name="ArtistName"
                               Text=""
                               FontFamily="pack://application:,,,/Fonts/#Interceptor"
                               FontSize="18"
                               TextAlignment="Left"/>
                    </Viewbox>

                    <!-- Album Art -->
                    <Border Width="240"
                            Height="240"
                            ClipToBounds="True"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,15">
                        <Image x:Name="AlbumArt"
                            Stretch="Uniform"/>
                    </Border>

                    <!-- Song Name -->
                    <Viewbox Stretch="Uniform"
                             StretchDirection="DownOnly"
                             Height="30"
                             Width="245"
                             Margin="0,0,0,10">

                        <TextBlock x:Name="SongName"
                               Text=""
                               FontFamily="pack://application:,,,/Fonts/#Interceptor"
                               FontSize="18"
                               TextAlignment="Center"/>
                    </Viewbox>

                    <TextBlock x:Name="SongLength"
                           Text=""
                           HorizontalAlignment="Center"
                           FontFamily="pack://application:,,,/Fonts/#Interceptor"
                           FontSize="12"
                           TextAlignment="Center"/>

                </StackPanel>

            </Grid>

            <!-- Media Buttons -->
            <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Margin="0,20,0,10">

                <Button x:Name="Shuffle"
                        Content="noShuff"
                        Width="50"
                        Height="50"
                        Margin="10"
                        Style="{StaticResource ImageButton}"
                        Tag="/Art/no-shuffle.png"
                        Uid="/Art/no-shuffle-highlight.png"
                        Click="Shuffle_Click"/>

                <Button x:Name="Prev"
                        Width="60"
                        Height="40"
                        Margin="10"
                        Style="{StaticResource ImageButton}"
                        Tag="/Art/next-prev-rev.png"
                        Uid="/Art/next-prev-rev-highlight.png"
                        Click="Prev_Click"/>

                <Button x:Name="Play"
                        Width="60"
                        Height="40"
                        Margin="10"
                        Style="{StaticResource ImageButton}"
                        Tag="/Art/play.png"
                        Uid="/Art/play-highlight.png"
                        Click="Play_Click"/>

                <Button x:Name="Next"
                        Width="60"
                        Height="40"
                        Margin="10"
                        Style="{StaticResource ImageButton}"
                        Tag="/Art/next-prev.png"
                        Uid="/Art/next-prev-highlight.png"
                        Click="Next_Click"/>

                <Button x:Name="loop"
                        Content="No Loop"
                        Width="50"
                        Height="50"
                        Margin="10"
                        Style="{StaticResource ImageButton}"
                        Tag="/Art/no-loop.png"
                        Uid="/Art/no-loop-highlight.png"
                        Click="Loop_Click"/>

            </StackPanel>

            <!-- Song Progress -->
            <ProgressBar x:Name="SongProgress"
                         Grid.Row="1"
                         Height="9"
                         Margin="80,10,80,0"
                         MinWidth="220"
                         MaxWidth="640"
                         VerticalAlignment="Top"
                         Foreground="#FFAF3931"/>

            <!-- Volume Slider -->
            <Slider x:Name="Volume"
                        Grid.Row="2"
                        Minimum="0"
                        Maximum="100"
                        Width="200"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20"
                        ValueChanged="Volume_ValueChanged"/>

        </Grid>

        <Grid x:Name="librarySection"
                    Grid.Row="2"
                    Grid.RowSpan="3"
                    Grid.ColumnSpan="3"
                    Background="#1E1E1E"
                    Visibility="Collapsed">
            
            <DataGrid x:Name = "LibraryGrid"
                  Grid.Row="2"
                  Grid.RowSpan="3"
                  Grid.ColumnSpan="3"
                  Margin="20,10,20,30"
                  Visibility="Visible"
                  AutoGenerateColumns="False"
                  ColumnWidth="*"
                  RowHeight="23"
                  CanUserReorderColumns="False"
                  IsReadOnly="True"
                  RowBackground="Transparent"
                  AlternatingRowBackground="Transparent"
                  Background="Transparent"
                  HeadersVisibility="Column"
                  VerticalScrollBarVisibility="Hidden"
                  HorizontalGridLinesBrush="SkyBlue"
                  VerticalGridLinesBrush="Transparent"
                  Foreground="LightSkyBlue"
                  BorderThickness="0"
                  SelectionChanged="LibraryGrid_SelectionChanged"
                  >
                <DataGrid.RowHeaderStyle>
                    <Style TargetType="DataGridRowHeader">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </DataGrid.RowHeaderStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2B2B2B"/>
                        <Setter Property="Padding" Value="2,0,0,0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="TextWrapping" Value="NoWrap"/>

                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="TextWrapping" Value="NoWrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Album" Binding="{Binding Album}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                <Setter Property="TextWrapping" Value="NoWrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>

            </DataGrid>
        </Grid>

        <Grid x:Name="Playlists_section"
              Grid.Row="2"
              Grid.RowSpan="3"
              Grid.Column="0"
              Width="160"
              Background="#1E1E1E"
              Margin="0,0,0,10"
              Visibility="Visible">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>


            <!-- Header with button -->
            <Grid Grid.Row="0" Margin="5,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="RenamePlaylist"
                        Content="N"
                        Width="24"
                        Height="24" Click="RenamePlaylist_Click"/>
                <Button Grid.Column="1"
                        x:Name="DeletePlaylist"
                        Content="-"
                        Height="24"
                        Width="24" Click="DeletePlaylist_Click"/>

                <Button Grid.Column="2"
                        x:Name="NewPlaylistBtn"
                        Content="+"
                        Width="24"
                        Height="24"
                        Margin="0,0,0,0"
                        Click="NewPlaylist_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="5">
                <Grid x:Name="PlaylistEditSection">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- New Playlist Button -->
                    <Button x:Name="AddSong"
                        IsEnabled="False"
                        Content="Add"
                        Height="30"
                        Margin="5"
                        Click="AddSong_Click"/>

                    <Button x:Name="DeleteSong"
                        IsEnabled="False"
                        Grid.Column="1"
                        Content="Delete"
                        Height="30"
                        Margin="5"
                        Click="Delete_Click"/>
                </Grid>
                
                <TextBox x:Name ="RenameSection"
                         TextWrapping="Wrap" Text="Rename" 
                         Height="30"
                         Visibility="Collapsed" Background="White"
                         KeyDown="RenameSection_KeyDown"/>
            </Grid>
            <!-- List -->
                <ListView x:Name="PlaylistSelection"
                    Grid.Row="2"
                    Margin="5,0,5,5"
                    Background="#222"
                    BorderThickness="0"
                    SelectionChanged="PlaylistSelection_SelectionChanged">

                    <ListView.Resources>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#444"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.Resources>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>

    </Grid>
</Window>
