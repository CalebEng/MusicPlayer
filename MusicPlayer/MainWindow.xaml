<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Music Player" Height="600" Width="400"
        MinHeight="600"
        MinWidth="400"
        >

    <Grid>

        <!-- Define responsive layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Folder button -->
            <RowDefinition Height="*"/>
            <!-- Album art + text -->
            <RowDefinition Height="Auto"/>
            <!-- Media buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Slider -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- FOLDER BUTTON (Top Left) -->
        <Button x:Name="FolderFinder"
                Content="Folder"
                Grid.Row="0"
                Grid.Column="0"
                HorizontalAlignment="Left"
                Margin="10"
                Click="FindFolder"/>


        <!-- ALBUM ART + ARTIST + SONG (Centered) -->
        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center">

            <!-- Artist Name -->
            <TextBlock x:Name="ArtistName"
                       Text=""
                       FontSize="18"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>

            <!-- Album Art -->
            <Border Width="250" Height="250"
                    ClipToBounds="True"
                    HorizontalAlignment="Center"
                    Margin="0,10">
                <Image x:Name="AlbumArt"
                       Stretch="Uniform"/>
            </Border>

            <!-- Song Name -->
            <TextBlock x:Name="SongName"
                       Text=""
                       FontSize="18"
                       HorizontalAlignment="Center"
                       Margin="0,10"/>
        </StackPanel>


        <!-- MEDIA BUTTONS -->
        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20">

            <Button x:Name="Prev"
                    Content="Prev"
                    Width="60"
                    Height="40"
                    Margin="10"
                    Click="Prev_Click"/>

            <Button x:Name="Play"
                    Content="Play"
                    Width="60"
                    Height="40"
                    Margin="10"
                    Click="Play_Click"/>

            <Button x:Name="Next"
                    Content="Next"
                    Width="60"
                    Height="40"
                    Margin="10"
                    Click="Next_Click"/>
        </StackPanel>


        <!-- SLIDER -->
        <Slider x:Name="Volume"
                Minimum="0"
                Maximum="100"
                Grid.Row="3"
                Grid.ColumnSpan="3"
                Width="200"
                HorizontalAlignment="Center"
                Margin="0,20"
                Value="100"
                ValueChanged="Volume_ValueChanged"/>

        <ProgressBar  x:Name="SongProgress"
                     Grid.ColumnSpan="3"
                     Height="9" Margin="80,10,80,0" 
                     HorizontalAlignment="Stretch"
                     MinWidth="240"
                     MaxWidth="640"
                     Grid.Row="2" VerticalAlignment="Top"
                     PreviewMouseUp="ProgressBar_PreviewMouseUp"/>

    </Grid>
</Window>
